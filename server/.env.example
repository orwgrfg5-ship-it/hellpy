# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://helppy:helppy@localhost:5432/helppy?schema=public"

# Secret used to sign JWT access tokens. Use a long random string in production.
JWT_SECRET="change-me-in-production"

# Port the API server listens on
PORT=4000

# Allowed origin for CORS / Socket.IO (your frontend URL)
CLIENT_ORIGIN="http://localhost:5173"

# Public base URL used to build uploaded-file links. Defaults to the request host.
# Set this in production (e.g. https://api.example.com).
PUBLIC_URL=""
